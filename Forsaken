-- BUTON SİSTEMİ
local function addToggle(text, pos, var)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size = UDim2.new(0, 350, 0, 45); btn.Position = pos
    btn.Text = text .. ": OFF"; btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30); btn.TextColor3 = Color3.new(1,1,1)
    btn.MouseButton1Click:Connect(function()
        _G[var] = not _G[var]
        btn.Text = text .. (_G[var] and ": ON" or ": OFF")
        btn.BackgroundColor3 = _G[var] and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(30, 30, 30)
    end)
end

