--// BARITONE CAVE FARMER (ULTRA SPEED & ANTI-BUG)
local Players = game:GetService("Players")
local lp = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- ESKİ GUI SİL
if lp.PlayerGui:FindFirstChild("BaritoneCave") then lp.PlayerGui.BaritoneCave:Destroy() end

local sg = Instance.new("ScreenGui", lp.PlayerGui)
sg.Name = "BaritoneCave"
sg.ResetOnSpawn = false

local openBtn = Instance.new("TextButton", sg)
openBtn.Size = UDim2.new(0, 50, 0, 50)
openBtn.Position = UDim2.new(1, -70, 0.5, -25)
openBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 200)
openBtn.Text = "O"; openBtn.TextColor3 = Color3.new(1, 1, 1)
openBtn.TextSize = 30; openBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", openBtn).CornerRadius = UDim.new(0, 10)

local main = Instance.new("Frame", sg)
main.Size = UDim2.new(0, 180, 0, 100)
main.Position = UDim2.new(0.5, -90, 0.5, -50)
main.BackgroundColor3 = Color3.fromRGB(45, 0, 70)
main.Visible = false
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 15)

local farmBtn = Instance.new("TextButton", main)
farmBtn.Size = UDim2.new(0.8, 0, 0.6, 0)
farmBtn.Position = UDim2.new(0.1, 0, 0.2, 0)
farmBtn.Text = "Farm"; farmBtn.BackgroundColor3 = Color3.fromRGB(100, 0, 180)
farmBtn.TextColor3 = Color3.new(1, 1, 1); farmBtn.TextSize = 25
Instance.new("UICorner", farmBtn)

openBtn.MouseButton1Click:Connect(function() main.Visible = not main.Visible end)

-- AYARLAR
getgenv().CaveFarm = false
local speed = 300 -- HIZI 300 YAPTIM (ÇOK HIZLI)

local function teleportSmooth(targetPos)
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or not getgenv().CaveFarm then return end

    local startPos = hrp.Position
    local distance = (startPos - targetPos).Magnitude
    local travelTime = distance / speed
    local startTime = tick()

    -- Tween yerine frame tabanlı hareket (Bug engellemek için)
    while tick() - startTime < travelTime and getgenv().CaveFarm do
        local alpha = (tick() - startTime) / travelTime
        hrp.CFrame = CFrame.new(startPos:Lerp(targetPos, alpha))
        RunService.Heartbeat:Wait()
    end
    
    if getgenv().CaveFarm then
        hrp.CFrame = CFrame.new(targetPos)
    end
end

farmBtn.MouseButton1Click:Connect(function()
    getgenv().CaveFarm = not getgenv().CaveFarm
    farmBtn.Text = getgenv().CaveFarm and "Stop" or "Farm"
    farmBtn.BackgroundColor3 = getgenv().CaveFarm and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(100, 0, 180)
    
    if getgenv().CaveFarm then
        task.spawn(function()
            while getgenv().CaveFarm do
                pcall(function()
                    local char = lp.Character
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    
                    -- 1. WATER ÜSTÜ (70 BLOK YÜKSEK - BUG OLMASIN DİYE DAHA YUKARI)
                    local water = workspace:FindFirstChild("Water", true)
                    if water then teleportSmooth(water.Position + Vector3.new(0, 70, 0)) end
                    
                    -- 2. STAGE 1-9
                    for i = 1, 9 do
                        if not getgenv().CaveFarm then break end
                        local stage = workspace:FindFirstChild("CaveStage" .. i, true)
                        if stage then
                            local part = stage:FindFirstChild("DarknessPart", true)
                            if part then teleportSmooth(part.Position + Vector3.new(0, 70, 0)) end
                        end
                    end
                    
                    -- 3. SANDIK
                    if getgenv().CaveFarm then
                        local endModel = workspace:FindFirstChild("TheEnd", true)
                        local chest = endModel and endModel:FindFirstChild("GoldenChest", true)
                        if chest then
                            teleportSmooth(chest.Position)
                            task.wait(0.2)
                            firetouchinterest(hrp, chest, 0)
                            firetouchinterest(hrp, chest, 1)
                        end
                    end
                    
                    -- ÖLÜNCE BEKLE
                    repeat task.wait(0.5) until (char:FindFirstChild("Humanoid") and char.Humanoid.Health <= 0) or not getgenv().CaveFarm
                    if getgenv().CaveFarm then
                        repeat task.wait(0.5) until (lp.Character and lp.Character:FindFirstChild("Humanoid") and lp.Character.Humanoid.Health > 0) or not getgenv().CaveFarm
                    end
                end)
                task.wait(0.1)
            end
        end)
    end
end)
