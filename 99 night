-- ================= TELEPORT FIND =================
makeBtn(pages["Teleport Find"],"Random Item Chest",0,function()
	local list = {}
	for _,v in pairs(workspace:GetDescendants()) do
		if v.Name == "Item Chest5" or v.Name == "Item Chest6" or v.Name == "Item Chest7" then
			table.insert(list,v)
		end
	end
	if #list > 0 then
		local c = list[math.random(#list)]
		hrp.CFrame = (c.PrimaryPart or c):GetPivot()
	end
end)

for i=1,4 do
	makeBtn(pages["Teleport Find"],"Child Teleport "..i,i*35,function()
		local name = i==1 and "Lost Child" or "Lost Child"..i
		local c = workspace:FindFirstChild(name,true)
		if c then hrp.CFrame = (c.PrimaryPart or c):GetPivot() end
	end)
end

-- ================= OTHER =================
local flying = false
makeBtn(pages["Other"],"Fly (250)",0,function()
	flying = not flying
end)

RunService.RenderStepped:Connect(function()
	if flying then
		hrp.Velocity = workspace.CurrentCamera.CFrame.LookVector * 250
	end
end)

makeBtn(pages["Other"],"Map Completer Beta",35,function()
	for _,tree in pairs(workspace:GetDescendants()) do
		if tree.Name == "Small Tree" and tree:IsA("Model") then
			local p = tree.PrimaryPart or tree:FindFirstChildWhichIsA("BasePart")
			if p then
				hrp.CFrame = p.CFrame + Vector3.new(0,3,0)
				task.wait(0.12)
			end
		end
	end
end)

-- ================= FAST CHEST =================
local fastChest = false
local original = {}

makeBtn(pages["Other"],"Fast Chest",70,function()
	fastChest = not fastChest

	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("ProximityPrompt") then
			if fastChest then
				if not original[v] then
					original[v] = v.HoldDuration
				end
				v.HoldDuration = 0.5
			else
				if original[v] then
					v.HoldDuration = original[v]
				end
			end
		end
	end
end)
