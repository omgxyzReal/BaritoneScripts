-- ================= TABS =================
local tabs = {"Bring","Teleport Location","Teleport Find","Other"}
local pages = {}

for i,name in ipairs(tabs) do
	local b = Instance.new("TextButton", main)
	b.Size = UDim2.new(0.25,0,0,30)
	b.Position = UDim2.new((i-1)*0.25,0,0,35)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(40,40,40)
	b.TextColor3 = Color3.new(1,1,1)

	local page = Instance.new("Frame", main)
	page.Size = UDim2.new(1,0,1,-65)
	page.Position = UDim2.new(0,0,0,65)
	page.Visible = false
	pages[name] = page

	b.MouseButton1Click:Connect(function()
		for _,p in pairs(pages) do p.Visible = false end
		page.Visible = true
	end)
end
pages["Bring"].Visible = true

local function makeBtn(parent,text,y,func)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(0.45,0,0,28)
	b.Position = UDim2.new(0.05,0,0,y)
	b.Text = text
	b.BackgroundColor3 = Color3.fromRGB(60,60,60)
	b.TextColor3 = Color3.new(1,1,1)
	b.MouseButton1Click:Connect(func)
end

-- ================= BRING =================
local bringScroll = Instance.new("ScrollingFrame", pages["Bring"])
bringScroll.Size = UDim2.new(1,0,1,0)
bringScroll.ScrollBarThickness = 6

local bringItems = {
"Fuel Canister","Oil Barrel","Coal","Steak","Morsel","Log","Chair",
"MedKit","Bandage","Broken Microwave","Old Car Engine","Carrot",
"Berry","Cake","Tyre","Cultist Gem","Diamond","Small Tree",
"Rifle","Rifle Ammo",
"Item Chest5","Item Chest6","Item Chest7",
"Strong Axe","Giant Sack"
}

local y = 0
for _,item in ipairs(bringItems) do
	makeBtn(bringScroll,item,y,function()
		local offset = 0
		for _,v in pairs(workspace:GetDescendants()) do
			if v.Name == item and v:IsA("Model") then
				local p = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
				if p then
					v:SetPrimaryPartCFrame(CFrame.new(hrp.Position + Vector3.new(offset,0,-6)))
					offset += 4
				end
			end
		end
	end)
	y += 32
end
bringScroll.CanvasSize = UDim2.new(0,0,0,y+10)

