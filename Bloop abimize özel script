-- [[ 🚀 ÖZELLİK 1: SANA ATTIĞIN SCRIPTEKİ AYNI MANTIK ]] --
local IsActive = false
local FastGrabBtn = Instance.new("TextButton", Main)
FastGrabBtn.Size = UDim2.new(0.9, 0, 0, 45)
FastGrabBtn.Text = "Fast Grab: OFF"
FastGrabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
FastGrabBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
FastGrabBtn.Font = Enum.Font.GothamBold
FastGrabBtn.TextSize = 16
Instance.new("UICorner", FastGrabBtn)

FastGrabBtn.MouseButton1Click:Connect(function()
    IsActive = not IsActive
    FastGrabBtn.Text = IsActive and "Fast Grab: ACTIVE" or "Fast Grab: OFF"
    FastGrabBtn.TextColor3 = IsActive and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(255, 50, 50)
end)

-- [] TETİKLEME SİSTEMİ (Senin attığın scriptteki kod)
PPS.PromptButtonHoldBegan:Connect(function(prompt)
    if IsActive then
        prompt.HoldDuration = 0
        task.spawn(function()
            prompt:InputHoldBegin()
            prompt:InputHoldEnd()
            if fireproximityprompt then 
                fireproximityprompt(prompt) 
            end
        end)
    end
end)

PPS.PromptShown:Connect(function(prompt)
    if IsActive then
        prompt.HoldDuration = 0
    end
end)

-- [[ 🚀 ÖZELLİK 2: FAKE PART ]] --
local PartActive = false
local FakePart = Instance.new("Part", workspace)
FakePart.Name = "BloopPlatform"
FakePart.Size = Vector3.new(15, 1, 15)
FakePart.Transparency = 1
FakePart.Anchored = true
FakePart.CanCollide = false

local FakePartBtn = Instance.new("TextButton", Main)
FakePartBtn.Size = UDim2.new(0.9, 0, 0, 45)
FakePartBtn.Text = "Fake Part: OFF"
FakePartBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
FakePartBtn.TextColor3 = Color3.fromRGB(255, 50, 50)
FakePartBtn.Font = Enum.Font.GothamBold
FakePartBtn.TextSize = 16
Instance.new("UICorner", FakePartBtn)

FakePartBtn.MouseButton1Click:Connect(function()
    PartActive = not PartActive
    FakePartBtn.Text = PartActive and "Fake Part: ON" or "Fake Part: OFF"
    FakePartBtn.TextColor3 = PartActive and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(255, 50, 50)
    FakePart.CanCollide = PartActive
    if not PartActive then FakePart.CFrame = CFrame.new(0, -1000, 0) end
end)

RunService.Heartbeat:Connect(function()
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and PartActive then
        FakePart.CFrame = CFrame.new(root.Position + Vector3.new(0, -3.5, 0))
    end
end)

OpenBtn.MouseButton1Click:Connect(function()
    Main.Visible = not Main.Visible
end)
